{
    "version": 4,
    "configurePresets": [
        {
            "name": "DandanWithSerialize",
            "displayName": "serialize",
            "description": "Preset to use with serialization features enabled",
            "binaryDir": "${sourceDir}/build",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "${sourceParentDir}/install",
                "DANDAN_BUILD_SERIALIZE": "OFF",
                "BUILD_TESTING": "ON",
                "JSON_DisableEnumSerialization": "ON"
            }
        }
    ]
}