{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Doxygen: Generate",
            "type": "shell",
            "command": "doxygen Doxyfile",
            "problemMatcher": {
                "owner": "doxygen",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):\\s+warning:\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "message": 3,
                    "severity": 4
                }
            },
            "group": "build"
        },
        {
            "label": "Doxygen: Clear Warnings",
            "type": "shell",
            // On Linux/macOS:
            "command": "echo ''",
            // On Windows, swap the above for:
            // "command": "echo.",
            "problemMatcher": {
                "owner": "doxygen", // <-- must match exactly
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):\\s+warning:\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "message": 3,
                    "severity": 4
                }
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "cppcheck",
            "type": "shell",
            "group": "build",
            "command": "cppcheck",
            "args": [
                "--enable=all",
                "--template=gcc",
                "--cppcheck-build-dir=.cache/cppcheck",
                "--project=build/compile_commands.json",
                "--std=c++17",
                "--enable=all",
                "--check-level=exhaustive",
                "--suppress=missingIncludeSystem",
                "--suppress=\\*:external/\\*",
                "--suppress=missingInclude",
                "--inconclusive",
                "-j 4",
            ],
            "problemMatcher": {
                "owner": "cppcheck",
                "fileLocation": "autoDetect",
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s*(warning|error):\\s*(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        }
    ]
}